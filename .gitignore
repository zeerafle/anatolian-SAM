# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Ignore everything inside any "data" directory
**/data/**/*

# Unignore all sub-directories inside "data" (so git can traverse them)
!**/data/**/

# Unignore CSV files anywhere under data
!**/data/**/*.csv

.env
**/.checkpoints/

notebooks/turkish_validation_stems
notebooks/turkish_sam_audio_lora
